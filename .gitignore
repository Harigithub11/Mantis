# ── Ship only the project: ignore everything at root, then allow-list ──────────
/*
!/.gitignore
!/README.md
!/app
!/docs

# ── Secrets (NEVER commit) ─────────────────────────────────────────────────────
**/.env
**/.env.local
**/.env.*.local

# ── Python ─────────────────────────────────────────────────────────────────────
**/.venv/
**/__pycache__/
*.pyc

# ── Node / Next.js ─────────────────────────────────────────────────────────────
**/node_modules/
**/.next/
**/next-env.d.ts

# ── Runtime data (regenerated by the seed scripts) ─────────────────────────────
app/backend/mantis.db
app/backend/uploads/

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log

# ── Dev-only tests, tooling & screenshots (not part of the submission) ─────────
app/backend/smoke_*.py
app/backend/tools_*.py
app/backend/real_test.py
app/frontend/e2e*.mjs
app/e2e-screens/
